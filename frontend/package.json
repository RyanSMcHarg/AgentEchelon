{
  "name": "agentechelon-frontend",
  "description": "AgentEchelon frontend monorepo — @ae/shared, @ae/chat (chat SPA), @ae/admin (admin console)",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:chat && npm run build:admin",
    "build:chat": "npm -w @ae/chat run build",
    "build:admin": "npm -w @ae/admin run build",
    "dev:chat": "npm -w @ae/chat run dev",
    "dev:admin": "npm -w @ae/admin run dev",
    "assert-no-admin-in-chat": "node scripts/assert-no-admin-in-chat.mjs",
    "lint": "eslint .",
    "test": "npm -ws --if-present run test"
  },
  "overrides": {
    "fast-xml-parser": "^5.8.0",
    "@aws-sdk/nested-clients": "^3.972.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.2"
  }
}
