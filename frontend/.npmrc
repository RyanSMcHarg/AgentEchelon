# npm hardening for AgentEchelon - see docs/SECURITY-NPM-SUPPLY-CHAIN.md
#
# Block install-time lifecycle scripts (preinstall / install / postinstall /
# prepare). These hooks are the primary code-execution vector for npm
# supply-chain attacks (e.g. the axios and Red Hat "Miasma" compromises of
# 2026): a poisoned dependency runs arbitrary code on your machine or in CI the
# moment it is installed. Build steps that genuinely need a script are run
# explicitly (see the doc) rather than on install.
ignore-scripts=true

# New dependencies are pinned to an exact version (no caret range) so the
# committed lockfile stays the single source of truth and a malicious
# patch/minor release cannot be silently adopted by a fresh resolve.
save-exact=true
