# AWS Configuration
VITE_AWS_REGION=us-east-1

# Cognito Configuration
VITE_USER_POOL_ID=your-user-pool-id
VITE_CLIENT_ID=your-client-id
VITE_IDENTITY_POOL_ID=your-identity-pool-id

# Credential Exchange Service (SPEC-CREDENTIAL-EXCHANGE) — REQUIRED.
# CDK output AgentEchelonCognitoAuth.CredentialExchangeApiUrl. The frontend gets
# bearer-pinned, classification-capped Chime credentials from the backend exchange.
# The exchange is the sole source of Chime credentials — there is no Identity-Pool
# fallback, so the app cannot reach Chime if this is unset.
VITE_CREDENTIAL_EXCHANGE_API_URL=https://<id>.execute-api.<region>.amazonaws.com/prod/

# Chime SDK Configuration
VITE_APP_INSTANCE_ARN=your-app-instance-arn
# (No bot ARN is needed here — channels enroll the per-tier bot server-side via create-conversation.)

# API Endpoints (from CDK stack outputs)
VITE_CREATE_CONVERSATION_API_URL=your-create-conversation-api-url
VITE_ADD_BOT_API_URL=your-add-bot-api-url
VITE_SHARE_CONVERSATION_API_URL=your-share-conversation-api-url
VITE_PRESIGNED_URL_API_URL=your-presigned-url-api-url
VITE_ANALYTICS_API_URL=your-analytics-api-url
# Whether cost sleep mode is deployed. Source: CDK output
# AgentEchelonAnalyticsAurora.SleepModeEnabled. Only when 'true' does the
# DeploymentStatusBanner poll GET /deployment/state; otherwise that route does
# not exist and polling it would 403 on every tick. Absent ⇒ treated as off.
VITE_SLEEP_MODE_ENABLED=false
# Client-events ingestion endpoint. Source: CDK output
# AgentEchelonAnalytics.ClientEventsApiUrl. The eventTrackingService.ts
# batches signup/signin/session/usage/error events and POSTs them here
# (Cognito-authed). Leave blank in dev and the service logs to console
# instead of POSTing.
VITE_CLIENT_EVENTS_API_URL=your-client-events-api-url
VITE_USER_MANAGEMENT_API_URL=your-user-management-api-url
VITE_ADMIN_CONVERSATIONS_API_URL=your-admin-conversations-api-url
VITE_USER_FEEDBACK_API_URL=your-user-feedback-api-url
# /battle admin API (SPEC-BATTLE.md). Source: CDK output
# AgentEchelonBattle.ChannelBattleApiUrl (opt-in battle stack — only present when
# deployed with enableBattle). Used by the MembersPanel "Battle Mode" toggle
# to enable/disable per-channel battle mode. Leave unset if /battle is off.
VITE_CHANNEL_BATTLE_API_URL=your-channel-battle-api-url
# /battle pick-the-winner API (SPEC-BATTLE.md scorecard). Source: CDK
# output AgentEchelonBattle.BattleOutcomeApiUrl. Used by the inline battle
# scorecard to record/read the user's head-to-head pick.
VITE_BATTLE_OUTCOME_API_URL=your-battle-outcome-api-url
# Experiments admin API (Experiments tab + /battle arming). Source: CDK
# output AgentEchelonExperiments.ExperimentsApiUrl (the A/B experiments table +
# admin API live in their own AgentEchelonExperiments stack). Used by the admin
# Experiments tab.
VITE_EXPERIMENTS_API_URL=your-experiments-api-url

# Optional model deployment overrides (must match backend CDK model keys)
# Supported keys: haiku, sonnet, opus, titan, gpt_oss_20b, gpt_oss_120b
# VITE_BASIC_MODEL_KEY=haiku
# VITE_STANDARD_MODEL_KEY=sonnet
# VITE_PREMIUM_MODEL_KEY=opus

# Analytics mode: 'athena' (default) or 'aurora' (enables advanced admin tabs)
# If not set, auto-detected by probing the backend endpoint
# VITE_ANALYTICS_MODE=athena
