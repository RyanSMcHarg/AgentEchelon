*.js
!jest.config.js
# Lambda handler source files (CommonJS runtime, not compiled output)
!lambda/*/index.js
!lambda/*/*/index.js
*.d.ts
node_modules

# CDK asset staging directory
.cdk.staging
cdk.out
# Synth-generated context cache (embeds account-specific AZ/lookups — not portable)
cdk.context.json

# Cognito trigger handlers are hand-written JS SOURCE (not compiled TS output); the blanket *.js
# rule above drops them from the Lambda asset on a clean-checkout deploy (which ships an empty
# handler and breaks ALL auth). Keep them tracked.
!lambda/cognito-triggers/*.js
