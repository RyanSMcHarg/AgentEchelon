{
  "name": "agent-interface-backend",
  "description": "AWS CDK infrastructure for Agent Interface — Chime SDK, Cognito, Bedrock, and Lambda stacks",
  "version": "0.1.0",
  "bin": {
    "backend": "bin/backend.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "jest",
    "cdk": "cdk",
    "doctor": "node scripts/deployment-doctor.mjs",
    "sync-context": "node scripts/sync-context.mjs",
    "sync-knowledge": "node scripts/sync-project-knowledge.mjs",
    "validate": "node scripts/validate.mjs",
    "provision-test-users": "node scripts/provision-test-users.mjs",
    "deploy": "node scripts/deploy.mjs",
    "deploy-frontend": "node scripts/deploy-frontend.mjs"
  },
  "overrides": {
    "fast-xml-parser": "^5.8.0",
    "@aws-sdk/core": "^3.974.0",
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@aws-sdk/client-athena": "^3.1029.0",
    "@aws-sdk/client-chime-sdk-identity": "^3.1029.0",
    "@aws-sdk/client-chime-sdk-messaging": "^3.1029.0",
    "@aws-sdk/client-cloudformation": "^3.1029.0",
    "@aws-sdk/client-cloudfront": "^3.1063.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1029.0",
    "@aws-sdk/client-dynamodb": "^3.1029.0",
    "@aws-sdk/client-lambda": "^3.1029.0",
    "@aws-sdk/client-lex-models-v2": "^3.1055.0",
    "@aws-sdk/client-rds": "3.1079.0",
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/client-ses": "^3.1029.0",
    "@aws-sdk/client-sns": "3.1079.0",
    "@aws-sdk/client-ssm": "^3.1029.0",
    "@aws-sdk/lib-dynamodb": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.1",
    "@types/uuid": "^10.0.0",
    "aws-cdk": "2.1033.0",
    "esbuild": "^0.27.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agent-runtime": "^3.1055.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1032.0",
    "@aws-sdk/client-firehose": "^3.1051.0",
    "@aws-sdk/client-secrets-manager": "^3.1030.0",
    "@aws-sdk/client-sts": "^3.1061.0",
    "@aws-sdk/rds-signer": "^3.1030.0",
    "@types/pg": "^8.20.0",
    "aws-cdk-lib": "2.215.0",
    "cdk-amazon-chime-resources": "^3.2.25",
    "constructs": "^10.0.0",
    "pg": "^8.20.0",
    "uuid": "^13.0.0"
  }
